APP_NAME="Awal"
APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# Upload/object storage. If omitted, uploads are stored locally under UPLOADS_DIR.
UPLOADS_DIR="/tmp/awal-uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_ENDPOINT_URL_S3=""
AWS_REGION="auto"
BUCKET_NAME=""

# Remote document extraction
DOC_PROCESSOR_BASE_URL=""
DOC_PROCESSOR_API_KEY=""
DOC_PROCESSOR_TIMEOUT_MS="600000"

# Remote AI services. The OpenAI-compatible generation endpoint can be Vast,
# RunPod, or any vLLM-compatible host.
EMBEDDING_BASE_URL=""
EMBEDDING_API_KEY=""
RERANK_BASE_URL=""
RERANK_API_KEY=""
VAST_OPENAI_BASE_URL=""
VAST_OPENAI_API_KEY=""
VAST_LLM_MODEL="Qwen/Qwen3-32B"
VAST_EMBEDDING_MODEL="BAAI/bge-m3"
VAST_RERANK_MODEL="BAAI/bge-reranker-v2-m3"

# RunPod GPU lifecycle automation. When enabled, Awal wakes a disposable
# RunPod Pod on demand, keeps /workspace on the Network Volume, and can
# terminate idle compute through /api/v1/gpu-runtime/idle-check.
RUNPOD_AUTOMATION_ENABLED="0"
RUNPOD_API_KEY=""
RUNPOD_NETWORK_VOLUME_ID="5j7pt6oruc"
RUNPOD_DATA_CENTER_ID="US-NE-1"
RUNPOD_POD_NAME_PREFIX="awal-32b"
RUNPOD_GPU_TYPE_IDS="NVIDIA RTX PRO 6000 Blackwell Server Edition,NVIDIA H200,NVIDIA H100 80GB HBM3"
RUNPOD_GPU_COUNT="1"
RUNPOD_CONTAINER_DISK_GB="50"
RUNPOD_IMAGE="runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04"
RUNPOD_RUNTIME_MODE="vllm"
RUNPOD_IDLE_MINUTES="45"
RUNPOD_HEALTH_ATTEMPTS="180"
RUNPOD_HEALTH_DELAY_MS="5000"
RUNPOD_QUICK_HEALTH_TIMEOUT_MS="5000"
RUNPOD_FAST_START="1"
RUNPOD_FORCE_INSTALL="0"
RUNPOD_KEEPALIVE="1"
AWAL_VENV_DIR="/workspace/venvs/awal-runtime"
HF_HOME="/workspace/.cache/huggingface"
GPU_RUNTIME_ADMIN_KEY=""
QWEN_PROFILE="32b"
VLLM_API_KEY="awal-runpod-key"
