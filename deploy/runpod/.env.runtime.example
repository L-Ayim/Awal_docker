PUBLIC_VLLM_PORT=8000
PUBLIC_DOCLING_PORT=8010
PUBLIC_EMBEDDING_PORT=8020
PUBLIC_RERANK_PORT=8030

# RunPod Network Volume is mounted at /workspace on Pods.
AWAL_VOLUME_DIR=/workspace
HF_HOME=/workspace/hf-cache
AWAL_MODEL_DIR=/workspace/models
AWAL_LOG_DIR=/workspace/logs

# 32B production test profile. For lower-cost tests, use:
# Qwen/Qwen3-14B, Qwen/Qwen3-8B, Qwen/Qwen3-4B-Instruct-2507.
VLLM_MODEL=Qwen/Qwen3-32B
VLLM_API_KEY=awal-runpod-key
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.88

DOC_PROCESSOR_API_KEY=awal-docling-key
DOCLING_DEVICE=cuda

EMBEDDING_API_KEY=awal-embedding-key
EMBEDDING_MODEL=BAAI/bge-m3

# Keep rerank optional on 32B boxes unless the GPU has enough spare VRAM.
ENABLE_RERANK=0
RERANK_API_KEY=awal-rerank-key
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Optional but recommended for faster Hugging Face downloads.
HF_TOKEN=

# Optional Backblaze B2/rclone config. Prefer using rclone config or env vars
# on the Pod rather than committing secrets here.
B2_REMOTE=b2
B2_BUCKET=awal-ai-storage
