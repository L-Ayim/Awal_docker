FROM runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/workspace/.cache/huggingface
ENV AWAL_VOLUME_DIR=/workspace
ENV AWAL_LOG_DIR=/workspace/logs
ENV AWAL_VENV_DIR=/opt/awal-venv
ENV RUNPOD_FAST_START=1
ENV RUNPOD_KEEPALIVE=1

WORKDIR /opt/awal

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git procps rclone rsync \
  && rm -rf /var/lib/apt/lists/*

COPY requirements-docling-service.txt requirements-docling-service.txt
COPY requirements-embedding-service.txt requirements-embedding-service.txt
COPY requirements-rerank-service.txt requirements-rerank-service.txt

RUN python -m venv /opt/awal-venv \
  && /opt/awal-venv/bin/python -m pip install --upgrade pip \
  && /opt/awal-venv/bin/python -m pip install vllm \
  && /opt/awal-venv/bin/python -m pip install \
    -r requirements-docling-service.txt \
    -r requirements-embedding-service.txt \
    -r requirements-rerank-service.txt

COPY . /opt/awal

RUN chmod +x /opt/awal/deploy/runpod/bootstrap-runpod.sh \
  && chmod +x /opt/awal/deploy/runpod/vllm/run-qwen3.sh

EXPOSE 8000 8010 8020 8030

CMD ["bash", "-lc", "mkdir -p /workspace/Awal /workspace/logs /workspace/.cache/huggingface && rsync -a --delete --exclude .git /opt/awal/ /workspace/Awal/ && bash /workspace/Awal/deploy/runpod/bootstrap-runpod.sh \"${QWEN_PROFILE:-32b}\""]
